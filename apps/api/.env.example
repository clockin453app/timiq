TIMIQ_ENV=local
TIMIQ_APP_NAME=TimIQ API
TIMIQ_API_HOST=127.0.0.1
TIMIQ_API_PORT=8000

# Session signing (required in production: must not be the default when TIMIQ_ENV is not "local")
SESSION_SECRET=change-this-with-a-secure-random-value

# --- Private blob storage (onboarding, clock selfies, work progress, etc.) ---
# Files are never served as public URLs; the API streams bytes after auth checks. DB stores relative keys only.
# Backend: local disk (default) or private S3-compatible object storage (AWS S3, Cloudflare R2, DO Spaces, MinIO).
TIMIQ_STORAGE_BACKEND=local

# Local disk root when TIMIQ_STORAGE_BACKEND=local (must be persistent in production).
TIMIQ_STORAGE_ROOT=C:/timiq-storage

# S3-compatible (only when TIMIQ_STORAGE_BACKEND=s3). Use a private bucket; do not enable public object ACLs.
# TIMIQ_S3_BUCKET=
# TIMIQ_S3_REGION=
# TIMIQ_S3_ENDPOINT_URL=
# TIMIQ_S3_ACCESS_KEY_ID=
# TIMIQ_S3_SECRET_ACCESS_KEY=
# Optional key prefix inside the bucket, e.g. timiq-prod/
# TIMIQ_S3_PREFIX=
# TIMIQ_S3_FORCE_PATH_STYLE=false

DATABASE_URL=postgresql+psycopg://timiq_app:timiq_local_password_change_me@localhost:5432/timiq_local

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Public web app origin for emailed links (reset password, invite, verify email).
# Production: set to your frontend URL, e.g. https://timiq-web.onrender.com (no trailing slash).
# Alias: TIMIQ_WEB_APP_URL
WEB_ORIGIN=http://localhost:3000

# Transactional email (optional locally; required in production for forgot-password / invites).
# TIMIQ_EMAIL_ENABLED=true
# WEB_ORIGIN must match the hostname users open in the browser.
# TIMIQ_EMAIL_FROM=noreply@yourdomain.com
# TIMIQ_EMAIL_FROM_NAME=TimIQ
# TIMIQ_SMTP_HOST=smtp.example.com
# TIMIQ_SMTP_PORT=587
# TIMIQ_SMTP_USERNAME=
# TIMIQ_SMTP_PASSWORD=
# TIMIQ_SMTP_USE_TLS=true
# Shorthand aliases also supported: SMTP_HOST, SMTP_FROM_EMAIL, SMTP_FROM_NAME, SMTP_ENABLED, etc.
