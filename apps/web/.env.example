# TimIQ web (Next.js) — copy to .env.local for local development.
# Production on Render: set NEXT_PUBLIC_API_URL in the dashboard (do not commit secrets).

# Empty = same-origin /api (e.g. reverse proxy). Local dev uses next.config.ts rewrites to FastAPI.
# Split Render services: set to your API public origin, e.g. https://timiq-api.onrender.com
NEXT_PUBLIC_API_URL=
