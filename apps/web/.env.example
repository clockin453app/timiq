# TimIQ web (Next.js) — copy to .env.local for local development.
# Do not commit secrets.

# Server-only (Render web build): public API origin for Next.js rewrites. Proxies /api and /health to FastAPI.
# Recommended production: set API_PROXY_URL=https://your-api.onrender.com and leave NEXT_PUBLIC_API_URL empty
# so the browser uses same-origin /api/... (reliable session cookies on mobile).
API_PROXY_URL=http://127.0.0.1:8000

# Optional browser-visible override. Empty = same-origin /api (rewrites must target the API — use API_PROXY_URL on Render).
# Only set if you intentionally want the browser to call the API host directly (cross-site cookies; not recommended for mobile).
NEXT_PUBLIC_API_URL=
